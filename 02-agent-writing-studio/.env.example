# 配置环境（复制到 apps/web/.env.local，Next.js 从此处加载）
DATABASE_URL=postgresql://hello-agent:hello-agent@localhost:5433/hello-agent_studio
BETTER_AUTH_SECRET=change-me-to-a-long-random-string
BETTER_AUTH_URL=http://localhost:3100
NEXT_PUBLIC_APP_URL=http://localhost:3100
# OpenAI 或 DeepSeek 等兼容接口（变量名统一用 OPENAI_*）
OPENAI_API_KEY=
# OpenAI: https://api.openai.com/v1  模型 gpt-4o-mini
# DeepSeek: https://api.deepseek.com/v1  模型 deepseek-chat
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat
COLLAB_WS_URL=ws://localhost:1234
NEXT_PUBLIC_COLLAB_WS_URL=ws://localhost:1234
NEXT_PUBLIC_ENABLE_COLLAB=true
